{
  "ti-embedded-debug.automaticallyRunDependencyCheck": true,
  "ti-embedded-debug.armToolchainPath": "/usr/bin",
  "cmake.generator": "Ninja",
  "cmake.useCMakePresets": "always",
  "cmake.defaultConfigurePreset": "gcc-debug",
  "cmake.defaultBuildPreset": "build",
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  "cmake.showOptionsMovedNotification": false,
  "cmake.configureEnvironment": {
    "MSPM0_SDK_ROOT": "${env:MSPM0_SDK_ROOT}",
    "JLINK_EXE": "${env:JLINK_EXE}",
    "JLINK_GDB_SERVER": "${env:JLINK_GDB_SERVER}",
    "NUEDC_MINIMAL_DEBUG": "OFF",
    "NUEDC_NO_ENCODER": "ON"
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "debug.openDebug": "openOnDebugBreak",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/build": true,
    "**/build-test": true
  },
  "search.exclude": {
    "**/build": true,
    "**/build-test": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "nuedc_car.syscfg": "ti_msp_dl_config.c, ti_msp_dl_config.h, device.opt, device.cmd.genlibs, device.lds.genlibs, device_linker.cmd, device_linker.lds"
  },
  "files.associations": {
    "ti_msp_dl_config.h": "c",
    "*.syscfg": "javascript"
  },
  "cortex-debug.armToolchainPath": "/usr/bin",
  "cortex-debug.gdbPath": "/usr/bin/arm-none-eabi-gdb"
}
