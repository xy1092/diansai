{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NUEDC_MINIMAL_DEBUG": "OFF",
        "NUEDC_NO_ENCODER": "OFF"
      }
    },
    {
      "name": "gcc-debug-encoder",
      "displayName": "GCC Debug (Encoder)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-encoder",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NUEDC_NO_ENCODER": "OFF"
      }
    },
    {
      "name": "gcc-debug-minimal",
      "displayName": "GCC Debug (Minimal Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NUEDC_MINIMAL_DEBUG": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "build-encoder",
      "configurePreset": "gcc-debug-encoder"
    },
    {
      "name": "build-minimal",
      "configurePreset": "gcc-debug-minimal"
    }
  ]
}
